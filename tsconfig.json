{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["pages/**/*.ts", "tests/**/*.ts", "playwright.config.ts"]
}
